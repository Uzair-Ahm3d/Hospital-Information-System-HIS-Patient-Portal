'use client';

import { useState, useEffect } from 'react';
import { motion } from 'framer-motion';
import { Loader2, Activity, User, Weight, Thermometer, HeartPulse, Calendar } from 'lucide-react';
import { toast } from 'sonner';
import { Dialog, DialogContent, DialogDescription, DialogHeader, DialogTitle } from '@/components/ui/dialog';
import { Label } from '@/components/ui/label';
import { Input } from '@/components/ui/input';
import { Button } from '@/components/ui/button';

interface Vitals {
  VIT_ID: number;
  VIT_PAT_NUMBER: string;
  VIT_PAT_NAME: string;
  VIT_WEIGHT: string;
  VIT_BODYTEMP: string;
  VIT_BP: string;
  VIT_PULSE_RATE: string;
  VIT_RESP_RATE: string;
  VIT_DATE_REC: string;
}

interface Props {
  vitals: Vitals | null;
  open: boolean;
  onClose: () => void;
  onSuccess: () => void;
}

export default function VitalsForm({ vitals, open, onClose, onSuccess }: Props) {
  const [loading, setLoading] = useState(false);
  const [formData, setFormData] = useState({
    patientNumber: vitals?.VIT_PAT_NUMBER || '',
    patientName: vitals?.VIT_PAT_NAME || '',
    weight: vitals?.VIT_WEIGHT || '',
    bodyTemp: vitals?.VIT_BODYTEMP || '',
    bp: vitals?.VIT_BP || '',
    pulseRate: vitals?.VIT_PULSE_RATE || '',
    respRate: vitals?.VIT_RESP_RATE || '',
    dateRec: vitals?.VIT_DATE_REC ? new Date(vitals.VIT_DATE_REC).toISOString().split('T')[0] : new Date().toISOString().split('T')[0],
  });

  useEffect(() => {
    if (vitals) {
      setFormData({
        patientNumber: vitals.VIT_PAT_NUMBER || '',
        patientName: vitals.VIT_PAT_NAME || '',
        weight: vitals.VIT_WEIGHT || '',
        bodyTemp: vitals.VIT_BODYTEMP || '',
        bp: vitals.VIT_BP || '',
        pulseRate: vitals.VIT_PULSE_RATE || '',
        respRate: vitals.VIT_RESP_RATE || '',
        dateRec: vitals.VIT_DATE_REC ? new Date(vitals.VIT_DATE_REC).toISOString().split('T')[0] : new Date().toISOString().split('T')[0],
      });
    } else {
      setFormData({
        patientNumber: '',
        patientName: '',
        weight: '',
        bodyTemp: '',
        bp: '',
        pulseRate: '',
        respRate: '',
        dateRec: new Date().toISOString().split('T')[0],
      });
    }
  }, [vitals]);

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setLoading(true);

    try {
      const endpoint = '/api/vitals';
      const method = vitals ? 'PUT' : 'POST';
      
      const body = vitals
        ? { id: vitals.VIT_ID, ...formData }
        : formData;

      const response = await fetch(endpoint, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (!response.ok) throw new Error('Failed to save vitals');

      toast.success(vitals ? 'Vitals updated successfully' : 'Vitals created successfully');
      onSuccess();
    } catch (error) {
      console.error('Error saving vitals:', error);
      toast.error('Failed to save vitals');
    } finally {
      setLoading(false);
    }
  };

  return (
    <Dialog open={open} onOpenChange={onClose}>
      <DialogContent className="max-w-3xl max-h-[90vh] overflow-y-auto bg-white dark:bg-slate-900 border-slate-200 dark:border-slate-800">
        <DialogHeader>
          <DialogTitle className="text-2xl font-bold text-slate-900 dark:text-white flex items-center gap-2">
            <div className="p-3 bg-sky-600/10 dark:bg-sky-400/10 rounded-lg">
              <Activity className="w-7 h-7 text-sky-600 dark:text-sky-400" />
            </div>
            {vitals ? 'Edit Vitals Record' : 'Add Vitals Record'}
          </DialogTitle>
          <DialogDescription className="text-slate-600 dark:text-slate-400">
            {vitals ? 'Update patient vital signs' : 'Record new patient vital signs'}
          </DialogDescription>
        </DialogHeader>

        <motion.form
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          onSubmit={handleSubmit}
          className="space-y-6 mt-4"
        >
          {/* Patient Information */}
          <div className="space-y-4">
            <h3 className="text-sm font-semibold text-slate-900 dark:text-white flex items-center gap-2 border-b border-slate-200 dark:border-slate-700 pb-2">
              <User className="w-4 h-4 text-sky-600 dark:text-sky-400" />
              Patient Information
            </h3>
            
            <div className="grid grid-cols-2 gap-4">
              <div className="space-y-2">
                <Label htmlFor="patientNumber" className="text-sm font-medium text-slate-700 dark:text-slate-300">
                  Patient Number *
                </Label>
                <Input
                  id="patientNumber"
                  required
                  value={formData.patientNumber}
                  onChange={(e) => setFormData({ ...formData, patientNumber: e.target.value })}
                  className="h-11 bg-white dark:bg-slate-800 border-slate-300 dark:border-slate-600 text-slate-900 dark:text-white focus:ring-sky-500 dark:focus:ring-sky-400"
                  placeholder="P-2024-001"
                  disabled={loading}
                />
              </div>

              <div className="space-y-2">
                <Label htmlFor="patientName" className="text-sm font-medium text-slate-700 dark:text-slate-300">
                  Patient Name *
                </Label>
                <Input
                  id="patientName"
                  required
                  value={formData.patientName}
                  onChange={(e) => setFormData({ ...formData, patientName: e.target.value })}
                  className="h-11 bg-white dark:bg-slate-800 border-slate-300 dark:border-slate-600 text-slate-900 dark:text-white focus:ring-sky-500 dark:focus:ring-sky-400"
                  placeholder="Enter patient name"
                  disabled={loading}
                />
              </div>
            </div>
          </div>

          {/* Vital Signs */}
          <div className="space-y-4">
            <h3 className="text-sm font-semibold text-slate-900 dark:text-white flex items-center gap-2 border-b border-slate-200 dark:border-slate-700 pb-2">
              <HeartPulse className="w-4 h-4 text-sky-600 dark:text-sky-400" />
              Vital Signs
            </h3>
            
            <div className="grid grid-cols-2 gap-4">
              <div className="space-y-2">
                <Label htmlFor="weight" className="text-sm font-medium text-slate-700 dark:text-slate-300 flex items-center gap-1.5">
                  <Weight className="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" />
                  Weight (kg) *
                </Label>
                <Input
                  id="weight"
                  required
                  value={formData.weight}
                  onChange={(e) => setFormData({ ...formData, weight: e.target.value })}
                  className="h-11 bg-white dark:bg-slate-800 border-slate-300 dark:border-slate-600 text-slate-900 dark:text-white focus:ring-sky-500 dark:focus:ring-sky-400"
                  placeholder="70.5"
                  disabled={loading}
                />
              </div>

              <div className="space-y-2">
                <Label htmlFor="bodyTemp" className="text-sm font-medium text-slate-700 dark:text-slate-300 flex items-center gap-1.5">
                  <Thermometer className="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" />
                  Temperature (°C) *
                </Label>
                <Input
                  id="bodyTemp"
                  required
                  value={formData.bodyTemp}
                  onChange={(e) => setFormData({ ...formData, bodyTemp: e.target.value })}
                  className="h-11 bg-white dark:bg-slate-800 border-slate-300 dark:border-slate-600 text-slate-900 dark:text-white focus:ring-sky-500 dark:focus:ring-sky-400"
                  placeholder="37.5"
                  disabled={loading}
                />
              </div>

              <div className="space-y-2">
                <Label htmlFor="bp" className="text-sm font-medium text-slate-700 dark:text-slate-300 flex items-center gap-1.5">
                  <Activity className="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" />
                  Blood Pressure *
                </Label>
                <Input
                  id="bp"
                  required
                  value={formData.bp}
                  onChange={(e) => setFormData({ ...formData, bp: e.target.value })}
                  className="h-11 bg-white dark:bg-slate-800 border-slate-300 dark:border-slate-600 text-slate-900 dark:text-white focus:ring-sky-500 dark:focus:ring-sky-400"
                  placeholder="120/80"
                  disabled={loading}
                />
              </div>

              <div className="space-y-2">
                <Label htmlFor="pulseRate" className="text-sm font-medium text-slate-700 dark:text-slate-300 flex items-center gap-1.5">
                  <HeartPulse className="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" />
                  Pulse Rate (bpm) *
                </Label>
                <Input
                  id="pulseRate"
                  required
                  value={formData.pulseRate}
                  onChange={(e) => setFormData({ ...formData, pulseRate: e.target.value })}
                  className="h-11 bg-white dark:bg-slate-800 border-slate-300 dark:border-slate-600 text-slate-900 dark:text-white focus:ring-sky-500 dark:focus:ring-sky-400"
                  placeholder="72"
                  disabled={loading}
                />
              </div>

              <div className="space-y-2">
                <Label htmlFor="respRate" className="text-sm font-medium text-slate-700 dark:text-slate-300 flex items-center gap-1.5">
                  <Activity className="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" />
                  Respiration Rate (rpm) *
                </Label>
                <Input
                  id="respRate"
                  required
                  value={formData.respRate}
                  onChange={(e) => setFormData({ ...formData, respRate: e.target.value })}
                  className="h-11 bg-white dark:bg-slate-800 border-slate-300 dark:border-slate-600 text-slate-900 dark:text-white focus:ring-sky-500 dark:focus:ring-sky-400"
                  placeholder="16"
                  disabled={loading}
                />
              </div>

              <div className="space-y-2">
                <Label htmlFor="dateRec" className="text-sm font-medium text-slate-700 dark:text-slate-300 flex items-center gap-1.5">
                  <Calendar className="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" />
                  Date Recorded *
                </Label>
                <Input
                  id="dateRec"
                  type="date"
                  required
                  value={formData.dateRec}
                  onChange={(e) => setFormData({ ...formData, dateRec: e.target.value })}
                  className="h-11 bg-white dark:bg-slate-800 border-slate-300 dark:border-slate-600 text-slate-900 dark:text-white focus:ring-sky-500 dark:focus:ring-sky-400"
                  disabled={loading}
                />
              </div>
            </div>
          </div>

          <div className="flex gap-3 pt-4 border-t border-slate-200 dark:border-slate-700">
            <Button
              type="button"
              variant="outline"
              onClick={onClose}
              disabled={loading}
              className="flex-1 border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800"
            >
              Cancel
            </Button>
            <Button
              type="submit"
              disabled={loading}
              className="flex-1 bg-sky-600 hover:bg-sky-700 dark:bg-sky-500 dark:hover:bg-sky-600 text-white shadow-lg"
            >
              {loading ? (
                <>
                  <Loader2 className="w-4 h-4 mr-2 animate-spin" />
                  Saving...
                </>
              ) : vitals ? (
                'Update Vitals'
              ) : (
                'Add Vitals'
              )}
            </Button>
          </div>
        </motion.form>
      </DialogContent>
    </Dialog>
  );
}
