@import "tailwindcss";

@layer base {
  :root {
    /* Light Mode - Professional Medical Theme */
    --background: 248 250 252;
    --foreground: 15 23 42;
    --card: 255 255 255;
    --card-foreground: 15 23 42;
    --popover: 255 255 255;
    --popover-foreground: 15 23 42;
    --primary: 14 165 233;
    --primary-foreground: 255 255 255;
    --secondary: 241 245 249;
    --secondary-foreground: 15 23 42;
    --muted: 241 245 249;
    --muted-foreground: 100 116 139;
    --accent: 14 165 233;
    --accent-foreground: 255 255 255;
    --destructive: 239 68 68;
    --destructive-foreground: 255 255 255;
    --border: 226 232 240;
    --input: 226 232 240;
    --ring: 14 165 233;
    --radius: 0.5rem;
    
    /* Medical Color Palette - Light */
    --medical-blue: 14 165 233;
    --medical-teal: 20 184 166;
    --medical-green: 34 197 94;
    --medical-purple: 139 92 246;
    --medical-red: 239 68 68;
    --medical-orange: 249 115 22;
  }

  .dark {
    /* Dark Mode - Professional Medical Theme */
    --background: 15 23 42;
    --foreground: 248 250 252;
    --card: 30 41 59;
    --card-foreground: 248 250 252;
    --popover: 30 41 59;
    --popover-foreground: 248 250 252;
    --primary: 56 189 248;
    --primary-foreground: 15 23 42;
    --secondary: 51 65 85;
    --secondary-foreground: 248 250 252;
    --muted: 51 65 85;
    --muted-foreground: 148 163 184;
    --accent: 56 189 248;
    --accent-foreground: 15 23 42;
    --destructive: 248 113 113;
    --destructive-foreground: 15 23 42;
    --border: 51 65 85;
    --input: 51 65 85;
    --ring: 56 189 248;
    
    /* Medical Color Palette - Dark */
    --medical-blue: 56 189 248;
    --medical-teal: 45 212 191;
    --medical-green: 74 222 128;
    --medical-purple: 167 139 250;
    --medical-red: 248 113 113;
    --medical-orange: 251 146 60;
  }

  * {
    border-color: rgb(var(--border));
  }

  body {
    background-color: rgb(var(--background));
    color: rgb(var(--foreground));
    font-feature-settings: "rlig" 1, "calt" 1;
  }

  /* Smooth theme transition */
  * {
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }

  /* Custom Scrollbar Styles */
  ::-webkit-scrollbar {
    width: 10px;
    height: 10px;
  }

  ::-webkit-scrollbar-track {
    @apply bg-secondary;
    border-radius: 10px;
  }

  ::-webkit-scrollbar-thumb {
    background: linear-gradient(180deg, rgb(var(--medical-blue)), rgb(var(--medical-teal)));
    border-radius: 10px;
    border: 2px solid rgb(var(--background));
  }

  ::-webkit-scrollbar-thumb:hover {
    opacity: 0.8;
  }
}

@layer components {
  /* Page Transition Animations */
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes scaleIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes shimmer {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }

  .animate-fade-in {
    animation: fadeIn 0.3s ease-out;
  }

  .animate-slide-in-up {
    animation: slideInUp 0.4s ease-out;
  }

  .animate-slide-in-left {
    animation: slideInLeft 0.4s ease-out;
  }

  .animate-scale-in {
    animation: scaleIn 0.3s ease-out;
  }

  /* Background Gradients */
  .bg-hospital-gradient {
    @apply bg-linear-to-br from-slate-50 via-blue-50/30 to-slate-50;
  }
  
  .dark .bg-hospital-gradient {
    @apply bg-linear-to-br from-slate-950 via-slate-900 to-slate-950;
  }

  /* Sidebar Styles */
  .sidebar {
    @apply bg-white dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800;
    backdrop-filter: blur(10px);
  }

  /* Button Styles with Glow */
  .btn-primary {
    @apply bg-linear-to-r from-sky-500 to-cyan-500 dark:from-sky-400 dark:to-cyan-400;
    @apply text-white font-semibold px-4 py-2 rounded-lg;
    @apply shadow-lg shadow-sky-500/20 dark:shadow-sky-400/20;
    @apply transition-all duration-300;
    position: relative;
    overflow: hidden;
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    transition: left 0.5s;
  }

  .btn-primary:hover {
    @apply shadow-xl shadow-sky-500/40 dark:shadow-sky-400/40;
    transform: translateY(-2px);
  }

  .btn-primary:hover::before {
    left: 100%;
  }

  .btn-primary:hover span {
    text-shadow: 0 0 8px rgba(255, 255, 255, 0.8);
  }

  .btn-secondary {
    @apply bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-slate-100;
    @apply font-semibold px-4 py-2 rounded-lg;
    @apply transition-all duration-300;
  }

  .btn-secondary:hover {
    @apply bg-slate-200 dark:bg-slate-700;
    transform: translateY(-1px);
  }

  .btn-danger {
    @apply bg-linear-to-r from-red-500 to-rose-500 dark:from-red-400 dark:to-rose-400;
    @apply text-white font-semibold px-4 py-2 rounded-lg;
    @apply shadow-lg shadow-red-500/20 dark:shadow-red-400/20;
    @apply transition-all duration-300;
  }

  .btn-danger:hover {
    @apply shadow-xl shadow-red-500/40 dark:shadow-red-400/40;
    transform: translateY(-2px);
  }

  .btn-danger:hover span {
    text-shadow: 0 0 8px rgba(255, 255, 255, 0.8);
  }

  /* Card Styles */
  .card {
    @apply bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700;
    @apply shadow-lg transition-all duration-300;
  }

  .card:hover {
    @apply shadow-xl shadow-sky-500/10 dark:shadow-sky-400/10;
    transform: translateY(-2px);
  }

  .card-glass {
    @apply bg-white/80 dark:bg-slate-800/80 rounded-xl;
    @apply border border-slate-200/50 dark:border-slate-700/50;
    @apply shadow-xl backdrop-blur-xl transition-all duration-300;
  }

  /* Form Input Styles */
  .input-hospital {
    @apply w-full px-4 py-2.5 rounded-lg;
    @apply bg-white dark:bg-slate-800;
    @apply border border-slate-300 dark:border-slate-600;
    @apply text-slate-900 dark:text-slate-100;
    @apply placeholder:text-slate-400 dark:placeholder:text-slate-500;
    @apply focus:ring-2 focus:ring-sky-500 dark:focus:ring-sky-400;
    @apply focus:border-sky-500 dark:focus:border-sky-400;
    @apply transition-all duration-200;
  }

  .textarea-hospital {
    @apply input-hospital min-h-[100px] resize-y;
  }

  .select-hospital {
    @apply input-hospital appearance-none;
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 0.5rem center;
    background-repeat: no-repeat;
    background-size: 1.5em 1.5em;
    padding-right: 2.5rem;
  }

  /* Table Styles */
  .table-hospital {
    @apply w-full;
  }

  .table-hospital thead {
    @apply bg-slate-50 dark:bg-slate-800/50;
  }

  .table-hospital th {
    @apply px-6 py-4 text-left text-sm font-semibold;
    @apply text-slate-700 dark:text-slate-200;
    @apply border-b border-slate-200 dark:border-slate-700;
  }

  .table-hospital td {
    @apply px-6 py-4 text-sm;
    @apply text-slate-900 dark:text-slate-100;
    @apply border-b border-slate-100 dark:border-slate-800;
  }

  .table-hospital tr {
    @apply transition-colors duration-150;
  }

  .table-hospital tbody tr:hover {
    @apply bg-sky-50/50 dark:bg-sky-900/10;
  }

  /* Badge Styles */
  .badge {
    @apply inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium;
  }

  .badge-success {
    @apply bg-emerald-100 dark:bg-emerald-900/30 text-emerald-800 dark:text-emerald-300;
  }

  .badge-warning {
    @apply bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300;
  }

  .badge-danger {
    @apply bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-300;
  }

  .badge-info {
    @apply bg-sky-100 dark:bg-sky-900/30 text-sky-800 dark:text-sky-300;
  }

  .badge-purple {
    @apply bg-purple-100 dark:bg-purple-900/30 text-purple-800 dark:text-purple-300;
  }

  /* Modal Styles */
  .modal-backdrop {
    @apply fixed inset-0 bg-black/50 dark:bg-black/70 backdrop-blur-sm;
    @apply flex items-center justify-center p-4 z-50;
    animation: fadeIn 0.2s ease-out;
  }

  .modal-content {
    @apply bg-white dark:bg-slate-800 rounded-xl shadow-2xl;
    @apply max-w-2xl w-full max-h-[90vh] overflow-y-auto;
    animation: scaleIn 0.3s ease-out;
  }

  /* Utility Classes */
  .text-heading {
    @apply text-slate-900 dark:text-white font-bold;
  }

  .text-body {
    @apply text-slate-700 dark:text-slate-300;
  }

  .text-muted {
    @apply text-slate-500 dark:text-slate-400;
  }

  .hover-lift {
    @apply transition-transform duration-200;
  }

  .hover-lift:hover {
    transform: translateY(-2px);
  }

  /* Gradient Text */
  .text-gradient-medical {
    @apply bg-linear-to-r from-sky-600 to-cyan-600 dark:from-sky-400 dark:to-cyan-400;
    @apply bg-clip-text text-transparent;
  }
}

/* Keyframe Animations */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-30px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(30px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes floatUpDown {
  0%, 100% {
    transform: translateY(0px);
  }
  50% {
    transform: translateY(-10px);
  }
}

@keyframes pulseGlow {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.8;
    transform: scale(1.05);
  }
}

@keyframes gradientShift {
  0%, 100% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
}

@keyframes gradientFlow {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

@keyframes shimmer {
  0% {
    transform: translateX(-100%) rotate(45deg);
  }
  100% {
    transform: translateX(100%) rotate(45deg);
  }
}

@keyframes borderGlow {
  0%, 100% {
    opacity: 0.5;
  }
  50% {
    opacity: 1;
  }
}

/* Reduce motion for accessibility */
@media (prefers-reduced-motion: reduce) {
  .fade-in-up,
  .slide-in-left,
  .slide-in-right,
  .float-animation,
  .pulse-glow {
    animation: none;
  }
  
  .hover-lift:hover {
    transform: none;
  }
}
